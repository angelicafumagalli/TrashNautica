      - type: folder
        uid: NPP9wJjGqb4WFt
        colorClass: success
        icon: physics
        name: Giocatore
        lastmod: 1773852820960
        entries:
          - type: template
            baseClass: AnimatedSprite
            name: Giocatore
            depth: 0
            texture: R534r55TFdrtrj
            playAnimationOnStart: false
            loopAnimation: true
            animationFPS: 30
            visible: true
            events:
              - eventKey: OnStep
                lib: core
                code: |-
                  if (!pause.isPaused) {
                      var maxSpeed = 120 - 10 * this.spazzaturaGrande.length;
                      var friction = 0.05
                      if (this.hasCollidedWithEnemy) {
                          this.hspeed = !place.occupied(this, this.x + 10 * actions.P1MoveX.value, this.y, "Terreno") ? this.hspeed : -this.hspeed;
                          this.vspeed = !place.occupied(this, this.x, this.y + 10 * actions.P1MoveY.value, "Terreno") ? this.vspeed : -this.hspeed;

                      } else {
                          var targetSpeedX = actions.P1MoveX.down ? maxSpeed * actions.P1MoveX.value : 0;
                          var targetSpeedY = actions.P1MoveY.down ? maxSpeed * actions.P1MoveY.value : 0;

                          this.hspeed += (targetSpeedX - this.hspeed) * friction;
                          this.vspeed += (targetSpeedY - this.vspeed) * friction;
                          this.hspeed = !place.occupied(this, this.x + 10 * actions.P1MoveX.value, this.y, "Terreno") ? this.hspeed : 0;
                          this.vspeed = !place.occupied(this, this.x, this.y + 10 * actions.P1MoveY.value, "Terreno") ? this.vspeed : 0;
                      }

                      var offsetSpazzatura = 35;

                      for (let i = 0; i < this.spazzaturaGrande.length; i++) {
                          this.spazzaturaGrande[i].x = this.x;
                          this.spazzaturaGrande[i].y = this.y + (offsetSpazzatura * (i + 1));
                      }
                      
                      this.move();
                  }
                arguments: {}
              - eventKey: collisionCGroup
                code: |-
                  if (!this.hasCollidedWithEnemy && !pause.isPaused) {
                      this.hspeed = -this.hspeed;
                      this.vspeed = -this.vspeed;
                      
                      if (this.spazzaturaGrande.length > 0) {
                          // TODO: Gestione migliore della posizione nuova della spazzatura
                          do {
                              var maxDist = 40;
                              var targetDeltaX = Math.floor(Math.random() * maxDist) - maxDist/2;
                              var targetDeltaY = Math.floor(Math.random() * maxDist) - maxDist/2;
                              var validDelta = false;

                              validDelta = place.occupied(this, this.x + targetDeltaX, this.y + targetDeltaX, 'Terreno');
                          } while (validDelta != false);
                          
                          this.spazzaturaGrande[this.spazzaturaGrande.length - 1].x += targetDeltaX;
                          this.spazzaturaGrande[this.spazzaturaGrande.length - 1].y += targetDeltaY;
                          this.spazzaturaGrande[this.spazzaturaGrande.length - 1].isCollected = false;
                          this.spazzaturaGrande.pop();
                      }

                      this.hasCollidedWithEnemy = true;

                      var blinkInterval = setInterval(() => {
                          if (!pause.isPaused) this.alpha = this.alpha == 1 ? 0.5 : 1;
                      }, 100);

                      setTimeout(() => {
                          this.hasCollidedWithEnemy = false;
                          clearInterval(blinkInterval);

                          this.alpha = 1;
                      }, 1500);
                  }
                arguments:
                  group: Nemici
                lib: place
              - eventKey: OnCreate
                code: |-
                  this.hasCollidedWithEnemy = false;
                  this.spazzaturaGrande = [];
                  if (!window.scoreP1) window.scoreP1 = 0;


                  camera.followX = false;
                  camera.follow = this;
                arguments: {}
                lib: core
              - eventKey: collisionTemplate
                code: |-
                  if (this.spazzaturaGrande.length > 0) {

                      window.scoreP1 += 100 * this.spazzaturaGrande.length;
                      for (let i of this.spazzaturaGrande) i.kill = true;

                      this.spazzaturaGrande = [];
                  }
                arguments:
                  template: w2cpWbbRcqhr4F
                lib: place
            extends:
              cgroup: Giocatore
              'editor:myCollidingCGroups': []
            lastmod: 1775392302981
            uid: DL9BczP5Cd4RMz
            behaviors: []
            extendTypes: ''
