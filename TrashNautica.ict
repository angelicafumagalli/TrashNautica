        tiles: []
        extends: {}
        lastmod: 1775397497917
        events:
          - eventKey: OnRoomStart
            code: |+
              countDown = 10; 

              this.isOver = false;

              this.text = Math.ceil(countDown).toString();

            arguments: {}
            lib: core
          - eventKey: OnDraw
            code: |-
              if (!this.isOver && !pause.isPaused) {
                  countDown -= u.time;

                  let timeInSec = Math.ceil(countDown);
                  if (timeInSec < 0) { timeInSec = 0; }
                  
                  let timerText = templates.list['Timer'][0];

                  if (timerText) {
                      timerText.text = timeInSec.toString();
                  }

                  if (countDown <= 0) {
                      this.finito = true;
                      
                      if (timerText) {
                          timerText.text = "FINE!";
                      }
                      
                      pause.togglePaused()
                  }
              }
            arguments: {}
            lib: core
        behaviors: []
        extendTypes: ''
        uid: w2JHmN6CqWDt9G
