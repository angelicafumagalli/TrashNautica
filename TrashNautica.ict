ctjsVersion: 5.3.1
backups: 3
language: typescript
notes: /* empty */
libs:
  place:
    gridX: 1024
    gridY: 1024
    debugMode: false
    debugText: 8
  pointer:
    startlocked: false
  keyboard: {}
  keyboard.polyfill: {}
  pointer.polyfill: {}
  gamepad: {}
  vkeys: {}
  transition: {}
  tween: {}
startroom: n8zd3bf8c5jPWg
contentTypes: []
actions:
  - name: P1MoveX
    methods:
      - code: keyboard.KeyD
      - code: keyboard.KeyA
        multiplier: -1
  - name: P1MoveY
    methods:
      - code: keyboard.KeyW
        multiplier: -1
      - code: keyboard.KeyS
  - name: P2MoveX
    methods:
      - code: keyboard.ArrowLeft
        multiplier: -1
      - code: keyboard.ArrowRight
  - name: P2MoveY
    methods:
      - code: keyboard.ArrowUp
        multiplier: -1
      - code: keyboard.ArrowDown
scripts:
  - name: tutto
    code: |+
      /* Use scripts to define frequent functions and import small libraries */

      // Gestione pausa
      const pause = {
          isPaused: false,
          togglePaused: function () {
              this.isPaused = !this.isPaused;
          }
      }

